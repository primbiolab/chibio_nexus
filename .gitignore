# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
*.spec
*.egg
.Python

# ── Entorno virtual ───────────────────────────────────────────
venv/
env/
